generator client {
  provider        = "prisma-client-js"
  output          = "../app/generated/db"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  passwordHash        String?
  image               String?
  createdAt           DateTime             @default(now())
  albums              Album[]
  memoryStories       MemoryStory[]
  notifications       Notification[]
  passwordResetTokens PasswordResetToken[]
  people              Person[]
  photos              Photo[]
  stories             Story[]
}

model Album {
  id              String    @id @default(cuid())
  name            String
  description     String?
  coverImage      String?
  createdAt       DateTime  @default(now())
  userId          String?
  parentId        String?
  deletedAt       DateTime?
  isPublic        Boolean   @default(false)
  shareToken      String?   @unique
  isCollaborative Boolean   @default(false)
  parent          Album?    @relation("AlbumToAlbum", fields: [parentId], references: [id], onDelete: Cascade)
  children        Album[]   @relation("AlbumToAlbum")
  user            User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos          Photo[]
}

model Photo {
  id           String    @id @default(cuid())
  url          String?
  imageData    String?
  altText      String
  description  String?
  createdAt    DateTime  @default(now())
  isFavorite   Boolean   @default(false)
  dateTaken    DateTime?
  userId       String?
  albumId      String?
  storyId      String?
  deletedAt    DateTime?
  isPublic     Boolean   @default(false)
  shareToken   String?   @unique
  cameraMake   String?
  cameraModel  String?
  lensModel    String?
  focalLength  Float?
  fNumber      Float?
  iso          Int?
  exposureTime String?
  latitude     Float?
  longitude    Float?
  locationName String?
  width        Int?
  height       Int?
  fileSize     Int?
  faces        FaceTag[]
  story        Story?    @relation(fields: [storyId], references: [id])
  album        Album?    @relation(fields: [albumId], references: [id])
  user         User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags         Tag[]     @relation("PhotoToTag")
}

model Person {
  id             String    @id @default(cuid())
  name           String
  avatarUrl      String?
  phone          String?
  email          String?
  socialLink     String?
  createdAt      DateTime  @default(now())
  userId         String
  baseDescriptor String?
  faces          FaceTag[]
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FaceTag {
  id         String   @id @default(cuid())
  photoId    String
  personId   String
  x          Float?
  y          Float?
  width      Float?
  height     Float?
  descriptor String?
  createdAt  DateTime @default(now())
  person     Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  photo      Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@unique([photoId, personId])
}

model Tag {
  id     String  @id @default(cuid())
  name   String  @unique
  photos Photo[] @relation("PhotoToTag")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MemoryStory {
  id        String   @id @default(cuid())
  userId    String
  dayMonth  String
  year      Int
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayMonth, year])
}

model Story {
  id              String   @id @default(cuid())
  title           String
  content         String?
  coverImage      String?
  createdAt       DateTime @default(now())
  userId          String
  isPublic        Boolean  @default(false)
  shareToken      String?  @unique
  isCollaborative Boolean  @default(false)
  photos          Photo[]
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
